@{
    ViewBag.Title = "Home Page";
}

<!-- Home page container with background color and padding -->
<div class="container-fluid text-center py-5" style="min-height: 100vh; background-color: #AFEEEE;">
    <div class="container">
        <!-- Welcome Message with enhanced styling -->
        <div class="row mb-5">
            <div class="col">
                <h1 class="display-4 text-primary">Welcome to the Contract Monthly Claim System</h1>
                <p class="lead text-secondary">Efficiently manage your claims and approvals with ease.</p>
            </div>
        </div>

        <!-- Button section with improved layout and button styles -->
        <div class="row justify-content-center">
            <div class="col-md-3 mb-3">
                <a href="/Claims/SubmitClaim" class="btn btn-lg btn-primary btn-block shadow-sm">Submit a Claim</a>
            </div>
            <div class="col-md-3 mb-3">
                <a href="/Claims/ListClaims" class="btn btn-lg btn-secondary btn-block shadow-sm">View Claims</a>
            </div>
            <div class="col-md-3 mb-3">
                <a href="/Claims/VerifyClaims" class="btn btn-lg btn-success btn-block shadow-sm">Verify Claims</a>
            </div>
        </div>

        <!-- Privacy Button with proper link to Privacy page -->
        <div class="row justify-content-center mt-4">
            <div class="col-md-3">
                <a href="/Home/Privacy" class="btn btn-lg btn-info btn-block shadow-sm">Privacy Policy</a>

                @{
                    ViewBag.Title = "Home Page";
                }
                <h2 class="text-center">Login</h2>

                <!-- Login Form -->
                <form asp-controller="Login" asp-action="Index" method="post">
                    <div class="form-group mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" class="form-control" id="username" name="username" required>
                    </div>

                    <div class="form-group mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email" required>
                    </div>

                    <div class="form-group mb-3">
                        <label for="role" class="form-label">Role</label>
                        <select class="form-select" id="role" name="role" required>
                            <option value="">Select a role</option>
                            <option value="Lecturer">Lecturer</option>
                            <option value="Academic Manager">Academic Manager</option>
                            <option value="Program Coordinator">Program Coordinator</option>
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control" id="password" name="password" required>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-block shadow-sm">Login</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
